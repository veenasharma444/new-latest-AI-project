                        }

                    ),

                    dbc.Col(

                        right_panel(),

                        md=5,

                        style={
                            "padding": "0"
                        }

                    )

                ],

                className="g-0",

                style={
                    "height": "100vh"
                }

            )

        ],

        fluid=True,

        style={

            "padding": "0",

            "margin": "0",

            "overflow": "hidden",

            "backgroundColor": "#F8FAFC"

        }

    )
