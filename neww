# ==========================
# FEATURE CARD
# ==========================

def feature_card(icon, title, subtitle):

    return dbc.Card(

        dbc.CardBody(

            [

                html.Div(

                    icon,

                    style={
                        "fontSize": "28px",
                        "marginBottom": "12px"
                    }

                ),

                html.H5(

                    title,

                    style={
                        "color": "white",
                        "fontWeight": "600"
                    }

                ),

                html.P(

                    subtitle,

                    style={
                        "color": "#CBD5E1",
                        "fontSize": "14px"
                    }

                )

            ]

        ),

        style={

            "background": "rgba(255,255,255,.05)",

            "border": "1px solid rgba(255,255,255,.12)",

            "borderRadius": "16px",

            "height": "170px"

        }

    )


