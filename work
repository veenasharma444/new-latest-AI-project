from dash import Input, Output, State, callback
from dash.exceptions import PreventUpdate

from core.auth import register_user
from core.app_db import User, Role
from core.db_connector import get_session

//////
@app.callback(

    Output("users-table", "data"),

    Input("btn-create-user", "n_clicks"),

    State("user-username", "value"),
    State("user-password", "value"),
    State("user-role", "value"),

    prevent_initial_call=True
)
def create_user(n, username, password, role):

    if not n:
        raise PreventUpdate

    register_user(
        username=username,
        email=f"{username}@dummy.com",
        name=username,
        password=password,
        role_id=role
    )

    return get_all_users()

/////////
@app.callback(
    Output("users-table", "data"),
    Input("url", "pathname")
)
def load_users(path):

    if path != "/users":
        raise PreventUpdate

    return get_all_users()


