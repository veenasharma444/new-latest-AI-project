/* ===========================
   COMPANY TABLE
=========================== */

.table {
    margin-bottom: 0;
}

.table thead th {
    background: #F8FAFC;
    border-bottom: 2px solid #E5E7EB;
    color: #374151;
    font-weight: 600;
    padding: 14px 18px;
}

.table tbody td {
    padding: 16px 18px;
    vertical-align: middle;
}

.table tbody tr:hover {
    background: #F9FAFB;
}

.table-responsive {
    border: 1px solid #E5E7EB;
    border-radius: 12px;
    overflow: hidden;
}
