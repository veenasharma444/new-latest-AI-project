
from dash import html, dcc
import dash_bootstrap_components as dbc
from components.admin_layout import admin_layout


def generate_portal_page():

    body = html.Div(

        [

            dbc.Card(

                dbc.CardBody(

                    [

                        html.H3(
                            "Onex AI Data Insight Portal",
                            className="fw-bold"
                        ),

                        html.P(
                            "Select a company to access its dashboard.",
                            style={
                                "color": "#6B7280",
                                "marginBottom": "30px"
                            }
                        ),

                        dbc.Row(

                            [

                                dbc.Col(

                                    [

                                        dbc.Label(
                                            "Company",
                                            className="fw-semibold"
                                        ),

                                        dcc.Dropdown(

                                            id="portal-company-dropdown",

                                            placeholder="Select Company",

                                            options=[],

                                            clearable=False

                                        )

                                    ],

                                    md=8

                                ),

                                dbc.Col(

                                    [

                                        dbc.Button(

                                            "Access Workspace",

                                            id="btn-open-company",

                                            color="primary",

                                            className="w-100"

                                        )

                                    ],

                                    md=4,

                                    className="d-flex align-items-end"

                                )

                            ],

                            className="g-3"

                        ),

                        html.Hr(className="my-4"),

                        html.Div(

                            id="portal-company-info"

                        )

                    ]

                ),

                className="shadow-sm border-0 rounded-4"

            )

        ]

    )

    return admin_layout(

        title="Portal",

        body=body,

        active="portal"

    )
