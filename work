    State('session-state', 'data'),
    prevent_initial_call=True
)

def handle_signin(user_click, user_username, user_password, company_id, session_data):
    print("handle_signin fired")
    
    if user_click is None or user_click == 0:
        raise dash.exceptions.PreventUpdate
    
    button = ctx.triggered_id

    if button == "auth-btn-signin":
        username = user_username
        password = user_password

    # elif button == "auth-btn-admin-login":
    #     username = admin_username
    #     password = admin_password

    else:
        raise dash.exceptions.PreventUpdate

    print("Signin clicked", button, username)

    if not username or not password:
        return dash.no_update, dbc.Alert(
            "Please enter username and password",
            color="warning"
        ), dash.no_update
    session_data = session_data or {}

    from core.auth import register_user, authenticate_user
    result = authenticate_user(username, password)
    
    from core.auth import get_user_companies
    companies = get_user_companies(
        result["user_data"]["id"]
    ) if result["success"] else []

    if result["success"]:
        if company_id is None:
            return dash.no_update, dbc.Alert(
                "Please select a company",
                color="warning"
            ), dash.no_update
            

    if result['success']:
        # Allow only normal users
        if result['user_data']['role_id'] != 2:  # Assuming role_id 1=Admin, 2=User
            return dash.no_update, dbc.Alert("Access denied: This is Admin account", color="danger"), dash.no_update
        
        # result = authenticate_user(username, password)
        session_data.update({
                "is_authenticated": True,
                "username": result['user_data']['username'],
                "user_id": result['user_data']['id'],
                "email": result['user_data']['email'],
                "name": result['user_data']['name'],
                "role_id": result['user_data']['role_id'],
                "companies": companies,
                "selected_company_id": company_id,
                "company_id": company_id
            })

        return '/upload', dash.no_update, session_data
        # print("✅ LOGIN SUCCESS → redirecting")
    
    return dash.no_update, dbc.Alert(result['message'], color="danger"), dash.no_update


