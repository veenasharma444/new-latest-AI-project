from core.app_db import User, Role
from core.db_connector import get_session


def get_all_users():
    session = get_session()

    try:
        users = (
            session.query(User)
            .outerjoin(Role)
            .all()
        )

        data = []

        for user in users:
            data.append({
                "user_id": user.user_id,
                "action": "✏️",
                "username": user.username,
                "role": user.role.role_name if user.role else "",
                "status": user.is_active
            })

        return data

    finally:
        session.close()



