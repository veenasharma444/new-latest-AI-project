    if session_data is None:
        session_data = {}

    if kpi_data:
        session_data['kpi_selections'] = kpi_data
    if filter_data:
        session_data['filter_selections'] = filter_data
    if confirmed_dtypes:
        session_data['confirmed_dtypes'] = confirmed_dtypes
    if objective_data:
