"""LiteLLM/OpenAI compatible inference provider"""

import requests

from llm.base_provider import LLMProvider
from llm.prompts import DATASET_ANALYSIS_PROMPT


class OllamaProvider(LLMProvider):
    """LiteLLM Provider (OpenAI compatible API)"""

    def __init__(
        self,
        base_url: str = "https://litellm.osourceglobal.com/v1",
        model: str = "local-qwen3.6:35b-a3b",
        api_key: str = ""
    ):
        self.base_url = base_url.rstrip("/")
        self.model = model
        self.api_key = api_key
        self.timeout = 300

    def analyze_dataset(
        self,
        profiles_json: str,
        sample_data: str,
        user_context: str = None,
        include_sample_data: bool = True,
    ) -> str:

        prompt = self._build_prompt(
            profiles_json,
            sample_data if include_sample_data else "",
            user_context,
        )

        try:

            print(f"[INFO] Base URL : {self.base_url}")
            print(f"[INFO] Model    : {self.model}")

            headers = {
                "Content-Type": "application/json",
                "api-key": self.api_key,
            }

            payload = {
                "model": self.model,
                "messages": [
                    {
                        "role": "user",
                        "content": prompt
                    }
                ],
                "temperature": 0.2,
                "stream": False,
            }

            response = requests.post(
                f"{self.base_url}/chat/completions",
                headers=headers,
                json=payload,
                timeout=self.timeout,
            )

            print(f"[DEBUG] Response Status: {response.status_code}")

            response.raise_for_status()

            data = response.json()

            content = (
                data.get("choices", [{}])[0]
                    .get("message", {})
                    .get("content", "")
            )

            print("\n===== LLM RESPONSE =====")
            print(content[:5000])
            print("========================\n")

            return content

        except requests.exceptions.HTTPError:
            print(response.text)
            return "{}"

        except Exception as e:
            print(f"[ERROR] {e}")
            return "{}"

    def generate_text(self, prompt: str) -> str:

        try:

            headers = {
                "Content-Type": "application/json",
                "api-key": self.api_key,
            }

            payload = {
                "model": self.model,
                "messages": [
                    {
                        "role": "user",
                        "content": prompt
                    }
                ],
                "temperature": 0.3,
                "stream": False,
            }

            response = requests.post(
                f"{self.base_url}/chat/completions",
                headers=headers,
                json=payload,
                timeout=60,
            )

            response.raise_for_status()

            data = response.json()

            return (
                data.get("choices", [{}])[0]
                    .get("message", {})
                    .get("content", "")
                    .strip()
            )

        except Exception as e:
            print(f"[WARN] generate_text failed: {e}")
            return ""

    def _build_prompt(
        self,
        profiles_json: str,
        sample_data: str,
        context: str = None,
    ) -> str:

        prompt = DATASET_ANALYSIS_PROMPT.format(
            column_profiles=profiles_json,
            sample_data=sample_data,
            context=context or "No additional context provided",
        )

        print("\n===== PROMPT =====")
        print(prompt[:3000])
        print("==================\n")

        return prompt
