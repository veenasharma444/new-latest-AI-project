import dash
from dash import Input, Output, State
from dash import html
from dash.exceptions import PreventUpdate
import dash_bootstrap_components as dbc
from core.auth import (register_user, get_all_users, update_user)



def build_user_rows(users):

    children = []

    for user in users:

        children.append(

            html.Tr(

                [

                    html.Td(
                        html.Button(
                            "✏️",
                            id={
                                "type": "edit-user",
                                "index": user["user_id"]
                            },
                            className="btn btn-link edit-btn"
                        )
                    ),

                    html.Td(user["username"]),

                    html.Td(
                        dbc.Badge(
                            user["role"],
                            color="primary",
                            pill=True
                        )
                    ),

                    html.Td(
                        dbc.Switch(
                            id={
                                "type": "toggle-user",
                                "index": user["user_id"]
                            },
                            value=user["is_active"]
                        )
                    )

                ]

            )

        )

    return children


def register_users_callbacks(app):

    @app.callback(
        Output("users-list", "children"),
        Input("url", "pathname")
    )
    
    def load_users(pathname):

        if pathname != "/users":
            raise PreventUpdate
        
        users = get_all_users()
        children = []
        for user in users:

            children.append(
                    html.Tr(
                        [

                            html.Td(
                                html.Button(
                                    "✏️",
                                    id={
                                        "type": "edit-user",
                                        "index": user["user_id"]
                                    },
                                    className="btn btn-link edit-btn"
                                )
                            ),

                            html.Td(user["username"]),

                            html.Td(
                                dbc.Badge(
                                    user["role"],
                                    color="primary",
                                    pill=True
                                )
                            ),

                            html.Td(
                                dbc.Switch(
                                    id={
                                        "type": "toggle-user",
                                        "index": user["user_id"]
                                    },
                                    value=user["is_active"]
                                )
                            )

                        ]
                    )
                )
        return build_user_rows(users)
        
    
