def update_user_status(user_id, status):
    session = get_session()

    try:
        user = session.query(User).filter_by(user_id=user_id).first()

        if user:
            user.is_active = status
            session.commit()

        return True

    except Exception:
        session.rollback()
        return False

    finally:
        session.close()

