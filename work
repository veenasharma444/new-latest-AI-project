from dash import html, dcc
import dash_bootstrap_components as dbc
from components.admin_layout import admin_layout


def generate_companies_page():

    body = html.Div(

        [

            html.Div(
                id="company-msg",
                className="mb-3"
            ),

            dbc.Card(

                dbc.CardBody(

                    [

                        html.H5(
                            "Create Company",
                            className="fw-bold mb-4"
                        ),

                        dbc.Row(

                            [

                                dbc.Col(

                                    [

                                        dbc.Label(
                                            "Company Name",
                                            className="fw-semibold"
                                        ),

                                        dbc.Input(
                                            id="company-name",
                                            placeholder="Enter company name"
                                        )

                                    ],

                                    md=4

                                ),

                                dbc.Col(

                                    [

                                        dbc.Label(
                                            "Company Code",
                                            className="fw-semibold"
                                        ),

                                        dbc.Input(
                                            id="company-code",
                                            placeholder="Enter company code"
                                        )

                                    ],

                                    md=4

                                ),

                                dbc.Col(

                                    [

                                        dbc.Label(
                                            "Status",
                                            className="fw-semibold"
                                        ),

                                        dcc.Dropdown(

                                            id="company-status",

                                            options=[
                                                {
                                                    "label": "Active",
                                                    "value": True
                                                },
                                                {
                                                    "label": "Inactive",
                                                    "value": False
                                                }
                                            ],

                                            value=True,

                                            clearable=False

                                        )

                                    ],

                                    md=4

                                )

                            ],

                            className="g-3"

                        ),

                        html.Br(),

                        dbc.Button(

                            "Create Company",

                            id="btn-create-company",

                            color="primary"

                        )

                    ]

                ),

                className="shadow-sm border-0 rounded-4 mb-4"

            ),

            dbc.Card(

                dbc.CardBody(

                    [

                        html.H5(

                            "Company List",

                            className="fw-bold mb-3"

                        ),

                        html.Div(
                            id="company-table"
                        )

                    ]

                ),

                className="shadow-sm border-0 rounded-4"

            )

        ]

    )

    return admin_layout(

        title="Company Master",

        body=body,

        active="companies"

    )

